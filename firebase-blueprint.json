{
  "entities": {
    "NewsItem": {
      "title": "NewsItem",
      "description": "A news or feed item to be displayed on the website.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the news item."
        },
        "content": {
          "type": "string",
          "description": "The content or description of the news."
        },
        "link": {
          "type": "string",
          "description": "Optional link for more information."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the news item was created."
        }
      },
      "required": ["title", "content", "createdAt"]
    },
    "NewsletterSubscriber": {
      "title": "NewsletterSubscriber",
      "description": "A user who subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "subscribedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user subscribed."
        }
      },
      "required": ["email", "subscribedAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session between a visitor and the AI assistant.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The anonymous user ID of the visitor."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat started."
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the last message was sent."
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat should be considered expired (3 days from creation)."
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "model"]
              },
              "text": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": ["role", "text", "timestamp"]
          }
        }
      },
      "required": ["userId", "createdAt", "lastUpdatedAt", "expiresAt", "messages"]
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "duties": {
          "type": "array",
          "items": { "type": "string" }
        },
        "challenges": { "type": "string" },
        "solutions": { "type": "string" },
        "achievements": { "type": "string" },
        "order": { "type": "number", "description": "Used for sorting projects" }
      },
      "required": ["name", "role", "duties"]
    }
  },
  "firestore": {
    "/news_feed/{newsId}": {
      "schema": {
        "$ref": "#/entities/NewsItem"
      },
      "description": "Stores news and feed items."
    },
    "/newsletter_subscribers/{subscriberId}": {
      "schema": {
        "$ref": "#/entities/NewsletterSubscriber"
      },
      "description": "Stores newsletter subscriptions."
    },
    "/chatSessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/ChatSession"
      },
      "description": "Stores all chat sessions."
    },
    "/projects/{projectId}": {
      "schema": {
        "$ref": "#/entities/Project"
      },
      "description": "Stores portfolio projects."
    }
  }
}
